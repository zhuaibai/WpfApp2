<Window
    x:Class="WpfApp2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfApp2"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="1294"
    Height="800"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None"
    mc:Ignorable="d">
    
    <!--<WindowChrome.WindowChrome>
        <WindowChrome
        GlassFrameThickness="0"
        ResizeBorderThickness="0"
        CaptionHeight="0"
        />
    </WindowChrome.WindowChrome>-->
    <Grid>
        <!--  背景颜色渐变  -->
        <Grid.Background>
            <RadialGradientBrush>
                <!--<GradientStop Offset="0" Color="#FF83A813" />
                <GradientStop Offset="0.5" Color="#FF749511" />
                <GradientStop Offset="1" Color="#FFB5E61D" />-->
                <GradientStop Offset="0" Color="#ff285173" />
                <GradientStop Offset="0.5" Color="#ff244967" />
                <GradientStop Offset="1" Color="#ff14273a" />
            </RadialGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Border BorderBrush="#5518aabd" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <!--  第一列  -->
                <StackPanel Orientation="Horizontal">
                    <!--  第一列  -->
                    <Image Margin="10,2" Source="Images/Logo.png" />

                    <!--  第一列  -->

                    <!--<TextBlock
                            Grid.Column="0"
                            Margin="5,0,0,0"
                            Padding="0,0,0,0"
                            VerticalAlignment="Center">
                            <Run
                                FontSize="20"
                                Foreground="White"
                                Text="BMS测试上位机" />
                            <LineBreak />
                            <Run
                                FontSize="13"
                                Foreground="White"
                                Text="让世界永不停电" />
                        </TextBlock>-->

                </StackPanel>



                <!--  第二列  -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="17" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock
                            Grid.Column="0"
                            Margin="5,0,0,0"
                            Padding="0,0,0,0"
                            VerticalAlignment="Center">
                            <Run
                                FontSize="20"
                                Foreground="#aaa"
                                Text="BMS测试上位机" />
                            <!--<LineBreak />-->
                            <!--<Run
                                FontSize="13"
                                Foreground="White"
                                Text="让世界永不停电" />-->
                        </TextBlock>
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        Orientation="Horizontal"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button
                            Click="BtnMin"
                            Content="&#xe676;"
                            Style="{StaticResource OperateBtnStyle}" />
                        <Button
                            Click="BtnMaximize"
                            Content="&#xe651;"
                            Style="{StaticResource OperateBtnStyle}" />
                        <Button
                            Click="BtnClose"
                            Content="&#xe85d;"
                            Style="{StaticResource OperateBtnStyle2}" />
                    </StackPanel>
                    <Border
                        Grid.Row="1"
                        BorderBrush="#5518aabd"
                        BorderThickness="0,1,0,0">
                        <Border.Background>
                            <VisualBrush
                                TileMode="FlipX"
                                Viewport="0,0,7,7"
                                ViewportUnits="Absolute">
                                <VisualBrush.Visual>
                                    <Line
                                        Stroke="Gray"
                                        StrokeThickness="1"
                                        X1="0"
                                        X2="10"
                                        Y1="10"
                                        Y2="0" />
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Grid>
        </Border>
        <!--  内容  -->
        <ContentControl Grid.Row="1" Content="{Binding ContentControl}" />
        <!--  底部花边  -->
        <Border
            Grid.Row="2"
            BorderBrush="#5518aabd"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>
                <!--  第一列  -->
                <Border BorderBrush="#5518aabd" BorderThickness="0,1,0,0">
                    <Border.Background>
                        <VisualBrush
                            TileMode="FlipX"
                            Viewport="0,0,7,7"
                            ViewportUnits="Absolute">
                            <VisualBrush.Visual>
                                <Line
                                    Stroke="Gray"
                                    StrokeThickness="1"
                                    X1="0"
                                    X2="10"
                                    Y1="10"
                                    Y2="0" />
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.Background>
                </Border>
                <!--  第二列  -->
                <TextBlock
                    Grid.Column="1"
                    Margin="0,0,5,0"
                    FontSize="15"
                    Foreground="White"
                    Text="泰琪丰电子有限公司版权所有" />
            </Grid>
        </Border>
    </Grid>
</Window>
