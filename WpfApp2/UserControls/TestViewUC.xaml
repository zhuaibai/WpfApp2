<UserControl
    x:Class="WpfApp2.UserControls.TestViewUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:convert="clr-namespace:WpfApp2.Tools.ConvertTool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfApp2.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!--  注册布尔值到文本的转换器  -->
        <convert:BooleanToTextConverter
            x:Key="BoolLeanToTextConvert"
            FalseText="不合格"
            TrueText="合格" />
        <convert:StringSubstringConverter x:Key="StringSubstringConverter"/>
        <!--  定义 ListViewItem 的样式  -->
        <Style x:Key="TestViewSty" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <!--  根据 IsImportant 属性的值设置背景颜色  -->
                <DataTrigger Binding="{Binding IsImportant}" Value="True">
                    <Setter Property="Background" Value="LightGreen" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsImportant}" Value="False">
                    <Setter Property="Background" Value="LightCoral" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!--  定义 ListViewItem 的样式  -->
        <Style x:Key="LogViewSty" TargetType="ListViewItem">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                            <ContentPresenter />
                        </Border>


                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F4FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="100" MaxWidth="250" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition MinWidth="300" MaxWidth="400" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />

        </Grid.RowDefinitions>

        <!--  返回配置界面  -->
        <Button
            Margin="5"
            Command="{Binding SwitchUC}"
            Tag="&#xe973;"
            Content="主页"
            FontSize="35"
            Style="{StaticResource BtnStyle}" />

        <!--  第一行 标题  -->
        <TextBlock
            Grid.ColumnSpan="4"
            HorizontalAlignment="Center"
            FontSize="30"
            Foreground="White"
            Text="测试界面" />

        <!--  第二行 串口显示、机器类型和日志显示  -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <!--  串口信息显示  -->
            <StackPanel Orientation="Vertical">
                <StackPanel
                    Grid.Column="0"
                    Margin="10,0,10,10"
                    Orientation="Vertical">
                    <GroupBox
                        Margin="5"
                        Padding="10"
                        BorderBrush="#9918aabd"
                        Foreground="White"
                        Header="串口 1 信息">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="串口号:" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Foreground="#ff2bedf1"
                                Text="{Binding SerialPort1.SelectedPort}" />
                        </Grid>
                    </GroupBox>
                    <GroupBox
                        Margin="5"
                        Padding="10"
                        BorderBrush="#9918aabd"
                        BorderThickness="1"
                        Foreground="White"
                        Header="串口 2 信息">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="串口号:" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Foreground="#ff2bedf1"
                                Text="{Binding SerialPort2.SelectedPort}" />
                        </Grid>
                    </GroupBox>
                    <GroupBox
                        Margin="5"
                        Padding="10"
                        BorderBrush="#9918aabd"
                        Foreground="White"
                        Header="机 器 类 型">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="串口号:" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Text="{Binding SerialPort2.SelectedPort}" />

                        </Grid>
                    </GroupBox>
                </StackPanel>
            </StackPanel>
            <!--  日志  -->
            <ListView
                x:Name="LogListView"
                Grid.Row="1"
                Margin="10"
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{StaticResource LogViewSty}"
                ItemsSource="{Binding LogEntries}"
                ScrollViewer.VerticalScrollBarVisibility="Hidden">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="10"
                                Foreground="#666666"
                                Text="{Binding Time,Converter={StaticResource StringSubstringConverter}}" />
                            <TextBlock
                                FontSize="14"
                                Foreground="#333333"
                                Text="{Binding Message}" />


                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <!--<GridSplitter Grid.Column="1" Grid.RowSpan="2" Width="3" Margin="0,10" HorizontalAlignment="Center" Background="Gray"/>-->
        </Grid>

        <Border
            Grid.Row="1"
            Grid.Column="1"
            Width="3"
            Margin="0,0,0,10"
            Background="Gray" />
        <!--  第二行 测试项目展示  -->
        <Grid
            Grid.Row="1"
            Grid.Column="2"
            Margin="40,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <Grid x:Name="column1" Grid.Column="0" />
            <Grid x:Name="column2" Grid.Column="1" />
            <Grid x:Name="column3" Grid.Column="2" />
        </Grid>
        <ListView
            x:Name="TestItemListView"
            Grid.Row="1"
            Grid.Column="2"
            Margin="10,0,10,10"
            ScrollViewer.VerticalScrollBarVisibility="Hidden"
            Background="Transparent"
            BorderThickness="0"
            ItemContainerStyle="{StaticResource TestViewSty}"
            ItemsSource="{Binding TestItems}">
            <ListView.View>
                <GridView AllowsColumnReorder="True">
                    <!--  设置第一列宽度为比例宽度 2*  -->
                    <GridViewColumn Width="{Binding ElementName=column1, Path=ActualWidth}" Header="ID">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="30" Text="{Binding Id}" />
                            </DataTemplate>

                        </GridViewColumn.CellTemplate>

                    </GridViewColumn>
                    <!--  设置第二列宽度为比例宽度 3*  -->
                    <GridViewColumn Width="{Binding ElementName=column2, Path=ActualWidth}" Header="名称">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="30" Text="{Binding Name}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>

                    </GridViewColumn>
                    <!--  设置第三列宽度为比例宽度 2*  -->
                    <GridViewColumn Width="{Binding ElementName=column3, Path=ActualWidth}" Header="是否通过">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="30" Text="{Binding IsImportant, Converter={StaticResource BoolLeanToTextConvert}}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>

                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Grid
            Grid.Row="1"
            Grid.Column="3"
            Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            
                <Button
                    Grid.Row="1"
                    Margin="5"
                    Command="{Binding StartCommand}"
                    Content="开始"
                    Tag="&#xe622;"
                    Style="{StaticResource BtnStyle2}"
                    FontSize="30" />
                <Button
                    Grid.Column="1"
                    Grid.Row="1"
                    Margin="5"
                    Tag="&#xe691;"
                    Command="{Binding StopCommand}"
                    Style="{StaticResource BtnStyle3}"
                    Content="停止"
                    FontSize="30" />
           
        </Grid>
        <!--  第二行 右侧属性显示  -->





    </Grid>
</UserControl>
