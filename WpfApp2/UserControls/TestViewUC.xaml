<UserControl
    x:Class="WpfApp2.UserControls.TestViewUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:convert="clr-namespace:WpfApp2.Tools.ConvertTool"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfApp2.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!--  注册布尔值到文本的转换器  -->
        <convert:BooleanToTextConverter x:Key="BooleanToTextConverter" ></convert:BooleanToTextConverter>
        <convert:StringSubstringConverter x:Key="StringSubstringConverter" />
        <!--  定义 ListViewItem 的样式  -->
        <Style x:Key="TestViewSty" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />

            <Style.Triggers>
                <!-- Flag=0 且 IsImportant=True 时为绿色 -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Flag}" Value="1" />
                        <Condition Binding="{Binding IsImportant}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="Green" />
                </MultiDataTrigger>

                <!-- Flag=0 且 IsImportant=False 时为红色 -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Flag}" Value="1" />
                        <Condition Binding="{Binding IsImportant}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFFF8080" />
                </MultiDataTrigger>

                <!-- Flag=1 时无论 IsImportant 为何值都为黄色 -->
                <DataTrigger Binding="{Binding Flag}" Value="0">
                    <Setter Property="Background" Value="Orange" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderThickness" Value="0" />

        </Style>


        <!--  定义 ListViewItem 的样式  -->
        <Style x:Key="LogViewSty" TargetType="ListViewItem">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                            <ContentPresenter />
                        </Border>


                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F4FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="100" MaxWidth="250" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition MinWidth="300" MaxWidth="400" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />

        </Grid.RowDefinitions>
        <Grid Grid.ColumnSpan="4" Grid.RowSpan="4" Panel.ZIndex="3">
            <UserControl VerticalAlignment="Center" HorizontalAlignment="Center" Content="{Binding Bubble}"></UserControl>
        </Grid>
        <Border
            Grid.ColumnSpan="4"
            Margin="5"
            Background="#1118aabd"
            CornerRadius="10" />
        <!--  返回配置界面  -->
        <Button
            Margin="10"
            Command="{Binding SwitchUC}"
            Content="主页"
            FontSize="35"
            Style="{StaticResource BtnStyle}"
            Tag="&#xe973;" />

        <!--  第一行 标题  -->
        <TextBlock
            Grid.ColumnSpan="4"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="30"
            Foreground="White"
            Text="测试界面" />

        <!--  第二行 串口显示、机器类型和日志显示  -->

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Border
                Margin="5"
                Background="#1118aabd"
                CornerRadius="10" />
            <Border
                Grid.Row="1"
                Margin="5,5,5,5"
                Background="#1118aabd"
                CornerRadius="10" />
            <!--  串口信息显示  -->
            <StackPanel Orientation="Vertical">
                <StackPanel
                    Grid.Column="0"
                    Margin="10,10,10,10"
                    Orientation="Vertical">
                    <GroupBox
                        Margin="5"
                        Padding="10"
                        BorderBrush="#9918aabd"
                        Foreground="White"
                        Header="串口 1 信息">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="串口号:" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Foreground="#ff2bedf1"
                                Text="{Binding SerialPort1.SelectedPort}" />
                        </Grid>
                    </GroupBox>
                    <GroupBox
                        Margin="5"
                        Padding="10"
                        BorderBrush="#9918aabd"
                        BorderThickness="1"
                        Foreground="White"
                        Header="串口 2 信息">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="串口号:" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Foreground="#ff2bedf1"
                                Text="{Binding SerialPort2.SelectedPort}" />
                        </Grid>
                    </GroupBox>
                    <GroupBox
                        Margin="5"
                        Padding="10"
                        BorderBrush="#9918aabd"
                        Foreground="White"
                        Header="机 器 类 型">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="机器:" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Foreground="#ff2bedf1"
                                FontSize="30"
                                Text="{Binding testMachine.MachineName}" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="功率:" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                FontSize="15"
                                Foreground="#ff2bedf1"
                                Text="{Binding testMachine.A_Hour}" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Text="电池电压:" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                FontSize="15"
                                HorizontalAlignment="Center"
                                Foreground="#ff2bedf1"
                                Text="{Binding testMachine.BatVol}" />

                        </Grid>
                    </GroupBox>
                </StackPanel>
            </StackPanel>
            <!--  日志  -->
            <ListView
                x:Name="LogListView"
                Grid.Row="1"
                Margin="10"
                Background="Transparent"
                BorderThickness="0"
                ItemContainerStyle="{StaticResource LogViewSty}"
                ItemsSource="{Binding LogEntries}"
                ScrollViewer.VerticalScrollBarVisibility="Hidden">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="10"
                                Foreground="#666666"
                                Text="{Binding Time, Converter={StaticResource StringSubstringConverter}}" />
                            <TextBlock
                                FontSize="14"
                                Foreground="#333333"
                                Text="{Binding Message}" />


                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <!--<GridSplitter Grid.Column="1" Grid.RowSpan="2" Width="3" Margin="0,10" HorizontalAlignment="Center" Background="Gray"/>-->
        </Grid>

        <Border
            Grid.Row="1"
            Grid.Column="1"
            Width="0"
            Margin="0,0,0,10"
            Background="Gray" />
        <!--  第二行 测试项目展示  -->
        <Border
            Grid.Row="1"
            Grid.Column="2"
            Margin="5"
            Background="#1118aabd"
            CornerRadius="10" />
        <Grid
            Grid.Row="1"
            Grid.Column="2"
            Margin="30,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <Grid x:Name="column1" Grid.Column="0" />
            <Grid x:Name="column2" Grid.Column="1" />
            <Grid x:Name="column3" Grid.Column="2" />
        </Grid>
        <ListView
            x:Name="TestItemListView"
            Grid.Row="1"
            Grid.Column="2"
            Margin="20,10,20,20"
            Background="Transparent"
            BorderThickness="0"
            ItemContainerStyle="{StaticResource TestViewSty}"
            ItemsSource="{Binding TestItems}"
            ScrollViewer.VerticalScrollBarVisibility="Hidden">
            <ListView.View>
                <GridView AllowsColumnReorder="True">

                    <!--  设置第一列宽度为比例宽度 2*  -->
                    <GridViewColumn Width="{Binding ElementName=column1, Path=ActualWidth}" Header="ID">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="30" Text="{Binding Id}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    
                    <!--  设置第二列宽度为比例宽度 3*  -->
                    <GridViewColumn Width="{Binding ElementName=column2, Path=ActualWidth}" Header="测试项目">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="30" Text="{Binding Name}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <!--  设置第三列宽度为比例宽度 2*  -->
                    <GridViewColumn Width="{Binding ElementName=column3, Path=ActualWidth}" Header="是否合格">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <!--<TextBlock FontSize="30" Text="{Binding IsImportant, Converter={StaticResource BooleanToTextConverter}}" />-->
                                <TextBlock FontSize="30">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource BooleanToTextConverter}">
                                            <Binding Path="IsImportant" />
                                            <Binding Path="Flag" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Grid
            Grid.Row="1"
            Grid.Column="3"
            Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Border
                Grid.ColumnSpan="2"
                Margin="5"
                Background="#1118aabd"
                CornerRadius="10" />
            <Button
                Grid.Row="1"
                Margin="5"
                Grid.ColumnSpan="2"
                Visibility= "{Binding StartVisible}"
                Command="{Binding StartCommand}"
                Content="开始"
                FontSize="45"
                Style="{StaticResource BtnStyle2}"
                Tag="&#xe622;" />
            <Button
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Visibility="{Binding StopVisible}"
                Margin="5"
                Command="{Binding StopCommand}"
                Content="停止"
                FontSize="45"
                Style="{StaticResource BtnStyle3}"
                Tag="&#xe691;" />

        </Grid>
        <!--  第二行 右侧属性显示  -->


        <!--  底边  -->
        <Border
            Grid.Row="2"
            Grid.ColumnSpan="4"
            Height="10"
            Margin="5"
            Background="#1118aabd"
            CornerRadius="5" />





    </Grid>
</UserControl>
