<UserControl x:Class="WpfApp2.UserControls.TestViewUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfApp2.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- 定义 ListViewItem 的样式 -->
        <Style TargetType="ListViewItem">
            <Setter Property="Height" Value="30"></Setter>
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <!-- 根据 IsImportant 属性的值设置背景颜色 -->
                <DataTrigger Binding="{Binding IsImportant}" Value="True">
                    <Setter Property="Background" Value="LightCoral"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsImportant}" Value="False">
                    <Setter Property="Background" Value="LightGreen"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MaxWidth="250"></ColumnDefinition>
            <ColumnDefinition Width="auto"></ColumnDefinition>
            <ColumnDefinition Width="4*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <!--返回配置界面-->
        <Button Content="返回"></Button>
        <!--标题-->
        <TextBlock Text="测试界面" Grid.ColumnSpan="3" HorizontalAlignment="Center" FontSize="30"></TextBlock>
        <!--串口信息显示-->
        <StackPanel Grid.Row="1" Orientation="Vertical">
            <StackPanel Grid.Column="0" Orientation="Vertical" Margin="10">
                <GroupBox Header="串口 1 信息" Margin="5" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="串口号:" Grid.Row="0" Grid.Column="0"/>
                        <TextBox Text="{Binding SerialPort1.SelectedPort}" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Text="波特率:" Grid.Row="1" Grid.Column="0"/>
                        <TextBox Text="{Binding SerialPort1.SelectedBaudRate}" Grid.Row="1" Grid.Column="1"/>
                        <TextBlock Text="数据位:" Grid.Row="2" Grid.Column="0"/>
                        <TextBox Text="{Binding SerialPort1.SelectedDataBits}" Grid.Row="2" Grid.Column="1"/>
                        <TextBlock Text="校验位:" Grid.Row="3" Grid.Column="0"/>
                        <TextBox Text="{Binding SerialPort1.SelectedParity}" Grid.Row="3" Grid.Column="1"/>
                        <TextBlock Text="停止位:" Grid.Row="4" Grid.Column="0"/>
                        <TextBox Text="{Binding SerialPort1.SelectedStopBits}" Grid.Row="4" Grid.Column="1"/>
                    </Grid>
                </GroupBox>
                <GroupBox Header="串口 2 信息" Margin="5" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="串口号:" Grid.Row="0" Grid.Column="0"/>
                        <TextBox Text="{Binding SerialPort2.SelectedPort}" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Text="波特率:" Grid.Row="1" Grid.Column="0"/>
                        <TextBox Text="{Binding SerialPort2.SelectedBaudRate}" Grid.Row="1" Grid.Column="1"/>
                        <TextBlock Text="数据位:" Grid.Row="2" Grid.Column="0"/>
                        <TextBox Text="{Binding SerialPort2.SelectedDataBits}" Grid.Row="2" Grid.Column="1"/>
                        <TextBlock Text="校验位:" Grid.Row="3" Grid.Column="0"/>
                        <TextBox Text="{Binding SerialPort2.SelectedParity}" Grid.Row="3" Grid.Column="1"/>
                        <TextBlock Text="停止位:" Grid.Row="4" Grid.Column="0"/>
                        <TextBox Text="{Binding SerialPort2.SelectedStopBits}" Grid.Row="4" Grid.Column="1"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </StackPanel>
        <!--<GridSplitter Grid.Column="1" Grid.RowSpan="2" Width="3" Margin="0,10" HorizontalAlignment="Center" Background="Gray"/>-->
        <Border Grid.Row="1" Grid.Column="1" Background="Gray" Margin="0,10" Width="3"></Border>
        <!--测试项目展示-->
        <Grid Grid.Row="1" Grid.Column="2" Margin="20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" x:Name="column1" />
            <Grid Grid.Column="1" x:Name="column2" />
            <Grid Grid.Column="2" x:Name="column3" />
        </Grid>
        <ListView Grid.Row="1" Grid.Column="2" ItemsSource="{Binding Items}" Margin="10">
            <ListView.View>
                <GridView  AllowsColumnReorder="True">
                    <!-- 设置第一列宽度为比例宽度 2* -->
                    <GridViewColumn Header="ID" Width="{Binding ElementName=column1,Path=ActualWidth}">
                        <GridViewColumn.CellTemplate   >
                            <DataTemplate>
                                <TextBlock Text="{Binding Id}" FontSize="14"/>
                            </DataTemplate>
                            
                        </GridViewColumn.CellTemplate>
                        
                    </GridViewColumn>
                    <!-- 设置第二列宽度为比例宽度 3* -->
                    <GridViewColumn Header="名称" Width="{Binding ElementName=column2,Path=ActualWidth}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="14"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                        
                    </GridViewColumn>
                    <!-- 设置第三列宽度为比例宽度 2* -->
                    <GridViewColumn Header="是否通过" Width="{Binding ElementName=column3,Path=ActualWidth}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsImportant}" FontSize="14"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                       
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
