<UserControl
    x:Class="WpfApp2.UserControls.TestViewUC"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfApp2.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    xmlns:convert="clr-namespace:WpfApp2.Tools.ConvertTool"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!--注册布尔值到文本的转换器-->
        <convert:BooleanToTextConverter x:Key="BoolLeanToTextConvert" TrueText="合格" FalseText="不合格"/>
        <!--  定义 ListViewItem 的样式  -->
        <Style x:Key="TestViewSty" TargetType="ListViewItem">
            <Setter Property="Height" Value="30" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <!--  根据 IsImportant 属性的值设置背景颜色  -->
                <DataTrigger Binding="{Binding IsImportant}" Value="True">
                    <Setter Property="Background" Value= "LightGreen"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsImportant}" Value="False">
                    <Setter Property="Background" Value="LightCoral" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!--  定义 ListViewItem 的样式  -->
        <Style x:Key="LogViewSty" TargetType="ListViewItem">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            CornerRadius="5">
                            <ContentPresenter/>
                        </Border>


                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F4FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MaxWidth="250" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            
        </Grid.RowDefinitions>
        
        <!--  返回配置界面  -->
        <Button
            Margin="5"
            Command="{Binding SwitchUC}"
            Content="返回"
            Style="{StaticResource BtnStyle}" />
        
        <!--  第一行 标题  -->
        <TextBlock
            Grid.ColumnSpan="4"
            HorizontalAlignment="Center"
            FontSize="30"
            Text="测试界面" />
        
        <!--  第二行 串口显示、机器类型和日志显示  -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <!--  串口信息显示  -->
            <StackPanel  Orientation="Vertical">
                <StackPanel
                    Grid.Column="0"
                    Margin="10"
                    Orientation="Vertical">
                    <GroupBox
                        Margin="5"
                        Padding="10"
                        Header="串口 1 信息">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="串口号:" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding SerialPort1.SelectedPort}" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="波特率:" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="{Binding SerialPort1.SelectedBaudRate}" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Text="数据位:" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Text="{Binding SerialPort1.SelectedDataBits}" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Text="校验位:" />
                            <TextBox
                                Grid.Row="3"
                                Grid.Column="1"
                                Text="{Binding SerialPort1.SelectedParity}" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Text="停止位:" />
                            <TextBox
                                Grid.Row="4"
                                Grid.Column="1"
                                Text="{Binding SerialPort1.SelectedStopBits}" />
                        </Grid>
                    </GroupBox>
                    <GroupBox
                        Margin="5"
                        Padding="10"
                        Header="串口 2 信息">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="串口号:" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding SerialPort2.SelectedPort}" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="波特率:" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="{Binding SerialPort2.SelectedBaudRate}" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Text="数据位:" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Text="{Binding SerialPort2.SelectedDataBits}" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Text="校验位:" />
                            <TextBox
                                Grid.Row="3"
                                Grid.Column="1"
                                Text="{Binding SerialPort2.SelectedParity}" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Text="停止位:" />
                            <TextBox
                                Grid.Row="4"
                                Grid.Column="1"
                                Text="{Binding SerialPort2.SelectedStopBits}" />
                        </Grid>
                    </GroupBox>
                    <GroupBox
                        Margin="5"
                        Padding="10"
                        Header="机 器 类 型">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="串口号:" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding SerialPort2.SelectedPort}" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="波特率:" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="{Binding SerialPort2.SelectedBaudRate}" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Text="数据位:" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Text="{Binding SerialPort2.SelectedDataBits}" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Text="校验位:" />
                            <TextBox
                                Grid.Row="3"
                                Grid.Column="1"
                                Text="{Binding SerialPort2.SelectedParity}" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Text="停止位:" />
                            <TextBox
                                Grid.Row="4"
                                Grid.Column="1"
                                Text="{Binding SerialPort2.SelectedStopBits}" />
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </StackPanel>
            <!--日志-->
            <ListView Grid.Row="1" ItemContainerStyle="{StaticResource LogViewSty}" x:Name="LogListView" ItemsSource="{Binding LogEntries}" Margin="10">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Time}" Width="150" FontSize="14" Foreground="#666666"/>
                            <TextBlock Text="{Binding Message}" FontSize="14" Foreground="#333333"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <!--<GridSplitter Grid.Column="1" Grid.RowSpan="2" Width="3" Margin="0,10" HorizontalAlignment="Center" Background="Gray"/>-->
        </Grid>

        <Border
            Grid.Row="1"
            Grid.Column="1"
            Width="3"
            Margin="0,10"
            Background="Gray" />
        <!-- 第二行 测试项目展示  -->
        <Grid
            Grid.Row="1"
            Grid.Column="2"
            Margin="20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>
            <Grid x:Name="column1" Grid.Column="0" />
            <Grid x:Name="column2" Grid.Column="1" />
            <Grid x:Name="column3" Grid.Column="2" />
        </Grid>
        <ListView
            x:Name="TestItemListView"
            Grid.Row="1"
            Grid.Column="2"
            Margin="10"
            ItemContainerStyle="{StaticResource TestViewSty}"
            ItemsSource="{Binding TestItems}">
            <ListView.View>
                <GridView AllowsColumnReorder="True">
                    <!--  设置第一列宽度为比例宽度 2*  -->
                    <GridViewColumn Width="{Binding ElementName=column1, Path=ActualWidth}" Header="ID">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="20" Text="{Binding Id}" />
                            </DataTemplate>

                        </GridViewColumn.CellTemplate>

                    </GridViewColumn>
                    <!--  设置第二列宽度为比例宽度 3*  -->
                    <GridViewColumn Width="{Binding ElementName=column2, Path=ActualWidth}" Header="名称">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="20" Text="{Binding Name}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>

                    </GridViewColumn>
                    <!--  设置第三列宽度为比例宽度 2*  -->
                    <GridViewColumn Width="{Binding ElementName=column3, Path=ActualWidth}" Header="是否通过">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="20" Text="{Binding IsImportant,Converter={StaticResource BoolLeanToTextConvert}}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>

                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Grid  Grid.Row="1" Grid.Column="3" Margin="0,0,0,10">
            <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal">
                <Button Content="开始" FontSize="30" Margin="5" Background="Green" Command="{Binding StartCommand}"></Button>
                <Button Content="停止" FontSize="30" Background="Red" Margin="5" Command="{Binding StopCommand}"></Button>
            </StackPanel>
        </Grid>
        <!--第二行 右侧属性显示-->
       
        
       
        
        
    </Grid>
</UserControl>
