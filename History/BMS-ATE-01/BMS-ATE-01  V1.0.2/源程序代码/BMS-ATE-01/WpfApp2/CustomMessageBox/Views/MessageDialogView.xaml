<Window x:Class="WpfApp2.CustomMessageBox.MessageDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2.CustomMessageBox"
        xmlns:vm="clr-namespace:WpfApp2.CustomMessageBox.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}" 
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
         Height="550" Width="800">
    <Window.Resources>

        <!-- 添加这个阴影效果资源 -->
        <DropShadowEffect x:Key="DialogShadow" 
                      BlurRadius="10" 
                      Color="#33000000" 
                      Direction="-45" 
                      ShadowDepth="3" 
                      Opacity="0.7"/>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>

        <Style x:Key="OkButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FF0078D7"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFE0E0E0"/>
            <Setter Property="Foreground" Value="#FF333333"/>
        </Style>
       
    </Window.Resources>
    <Border CornerRadius="10" BorderThickness="1" BorderBrush="#FFD0D0D0" Background="White"
            Effect="{StaticResource DialogShadow}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Grid Grid.Row="0" Height="40">
                <TextBlock Text="{Binding Title}" FontSize="30" FontWeight="Bold" 
                           VerticalAlignment="Center" Foreground="#FF333333"/>
                <!--<Button Command="{Binding CloseCommand}" 
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource CancelButtonStyle}" 
                        Content="✕" FontSize="14" MinWidth="30" Padding="0"/>-->
            </Grid>

            <!-- 内容区域 -->
            <Grid Grid.Row="1" Margin="0,10,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 图标区域 -->
                <Viewbox Grid.Column="0" Width="150" Height="150" Margin="0,0,20,0">
                    <Path Data="{Binding IconPathData}" Fill="{Binding IconBrush}"/>
                </Viewbox>

                <!-- 消息内容 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled" 
                              MaxHeight="300">
                    <TextBlock Text="{Binding Message}" 
                               FontSize="{Binding FontSize}" 
                               TextWrapping="Wrap"
                               Foreground="#FF333333" LineHeight="26"/>
                </ScrollViewer>
            </Grid>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" >
                <Button Command="{Binding CancelCommand}" Content="取消" Margin="0,0,20,0"
                        Style="{StaticResource BtnStyle7}"/>
                
                <Button Command="{Binding OkCommand}" Content="确定"  
                        Style="{StaticResource BtnStyle6}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
