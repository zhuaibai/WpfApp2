<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="GroupBoxMachineTypeSty" TargetType="GroupBox">
        <Setter Property="Margin" Value="10,3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <!--  左上角的线条  -->
                        <Polyline
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Points="0 30,0 10,10 0,30 0"
                            Stroke="#9918aabd"
                            StrokeThickness="1" />
                        <!--  左上 横的点  小圆  -->
                        <Ellipse
                            Width="4"
                            Height="4"
                            Margin="24,-2,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Fill="#9918aabd" />
                        <!--  左侧的点  小圆  -->
                        <Ellipse
                            Width="4"
                            Height="4"
                            Margin="-2,24,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Fill="#9918aabd" />

                        <!--  Moveto  -->
                        <Path
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Data="M0 0,3 3,30 3,33 0,68 0,73 7,78 7,78,10M8 0,25 0"
                            Stroke="#9918aabd" />

                        <!--  左下角的线条  -->
                        <Polyline
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Points="0 0,0 15,10 15"
                            Stroke="#9918aabd"
                            StrokeThickness="1" />

                        <!--  右下角的线  -->
                        <Polyline
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Points="10 0,0,10"
                            Stroke="#9918aabd"
                            StrokeThickness="1" />

                        <!--  右下角的三角形  -->
                        <Polygon
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Fill="#9918aabd"
                            Points="0 7,7 7,7 0" />

                        <!--  上面的线  -->
                        <Border
                            Margin="30,-0.5,78,0"
                            VerticalAlignment="top"
                            BorderBrush="#9918aabd"
                            BorderThickness="0,1,0,0" />
                        <!--  右边的线  -->
                        <Border
                            Margin="0,10"
                            HorizontalAlignment="Right"
                            BorderBrush="#9918aabd"
                            BorderThickness="0,0,1,0" />

                        <!--  下面的线  -->
                        <Border
                            Margin="10,0"
                            VerticalAlignment="Bottom"
                            BorderBrush="#9918aabd"
                            BorderThickness="0,0,0,1" />

                        <!--  左边的线  -->
                        <Border
                            Margin="-0.5,15"
                            HorizontalAlignment="Left"
                            BorderBrush="#9918aabd"
                            BorderThickness="1,0,0,0" />

                        <!--  文字前的装饰  -->
                        <Path
                            Margin="10,13"
                            Data="M0 0,3 0,5 4,3 8,0 8,3 4"
                            Fill="#9918aabd" />
                        <Path
                            Margin="16,13"
                            Data="M0 0,3 0,5 4,3 8,0 8,3 4"
                            Fill="#5518aabd" />
                        <TextBlock
                            Margin="25,8"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            FontWeight="Bold"
                            FontSize="25"
                            Foreground="White"
                            Text="{TemplateBinding Header}" />
                        <!--  显示内容  -->
                        <ContentPresenter />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>